{
  "expo": {
    "name": "MLPA EduTech",
    "slug": "EduacationApp",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon_mlpa.png",
    "scheme": "educationapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon_mlpa.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.condua1755.EduacationApp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon_mlpa.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon_mlpa.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c495e5f8-07eb-41dc-8ebc-2473ebb99b13"
      }
    }
  }
}